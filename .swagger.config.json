{
  "$schema": "./dist/.swagger2api.schema.json",
  "input": "http://172.50.109.244:5005/api/openapi.json",
  "output": "./src/api",
  "importTemplate": "import { request } from '@/utils/request';",
  "generator": "typescript",
  "requestStyle": "generic",
  "groupByTags": true,
  "overwrite": true,
  "prefix": "",
  "lint": "prettier --write",
  "methodNameIgnorePrefix": [],
  "addMethodSuffix": true,
  "headerComment": "",
  "filter": {
    "include": {
      "tags": []
    },
    "exclude": {
      "tags": []
    }
  },
  "options": {
    "addComments": true
  },
  "multiTagStrategy": "first"
}